# ============================================================
# .gitignore – SmartFarming EKS Project
# PENTING: File-file ini JANGAN PERNAH masuk ke Git
# ============================================================

# ── Secrets & Credentials ───────────────────────────────────
# Jangan pernah commit ini! Bisa kena charge ratusan dolar.
.env
.env.*
*.pem
*.key
*.p12
*.pfx
*credentials*
aws_credentials
terraform.tfvars          # Berisi nilai sensitif variable Terraform
*.tfvars
!terraform.tfvars.example  # Kecuali contoh (tanpa nilai asli)

# ── Terraform ───────────────────────────────────────────────
**/.terraform/
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform.lock.hcl
terraform.log
crash.log

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyc
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/
.pytest_cache/

# ── Docker ──────────────────────────────────────────────────
.docker/

# ── Kubernetes ──────────────────────────────────────────────
# Jangan commit kubeconfig! Berisi credentials cluster
kubeconfig
*.kubeconfig
.kube/

# ── OS & Editor ─────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.iml

# ── Logs ────────────────────────────────────────────────────
*.log
logs/
